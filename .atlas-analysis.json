  "keyFeatures": [
    "Multi-server dashboard with real-time monitoring",
    "Rust daemon for Docker container orchestration",
    "45+ granular permission nodes for access control",
    "Automated backups with retention policies",
    "Real-time WebSocket console and stats",
    "Blueprint system for common game servers",
    "OAuth support (Google, GitHub, Discord) with 2FA and passkeys",
    "REST API with full panel feature parity",
    "Plugin system for custom game support",
    "SFTP file access for server management"
  ],
  "publicApiSurface": [
    "POST /api/servers - Create server",
    "GET /api/servers/:id - Get server details",
    "POST /api/servers/:id/power - Power control (start/stop/restart)",
    "POST /api/servers/:id/command - Send console command",
    "GET /api/servers/:id/stats - Real-time server stats",
    "POST /api/backups - Create backup",
    "GET /api/backups - List backups",
    "POST /api/backups/:id/restore - Restore backup",
    "GET /api/nodes - List nodes",
    "POST /api/nodes - Register node",
    "GET /api/blueprints - List blueprints",
    "POST /api/blueprints - Create blueprint",
    "POST /api/members/invite - Invite subuser",
    "PUT /api/members/:id/permissions - Update permissions",
    "POST /api/webhooks - Create webhook",
    "GET /api/analytics - Server analytics",
    "WS /ws/console/:serverId - Console WebSocket",
    "WS /ws/stats/:serverId - Stats WebSocket"
  ]
}
